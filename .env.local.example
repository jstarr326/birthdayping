# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here  # generate with: openssl rand -base64 32

# Google OAuth (create at console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Database
# For local dev: leave unset (uses SQLite at ./local.db)
# For Vercel/production: set to your Neon Postgres connection string
# DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# Mac utility API key (generate any random string)
SYNC_API_KEY=your-sync-api-key

# Twilio (for SMS birthday reminders)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Vercel Cron secret (set in Vercel dashboard, used to authenticate cron jobs)
# CRON_SECRET=your-cron-secret
