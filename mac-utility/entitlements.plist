<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened runtime — required for notarization -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow loading pyobjc dynamic libraries -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Contacts access (CNContactStore) -->
    <key>com.apple.security.personal-information.addressbook</key>
    <true/>

    <!-- AppleScript / osascript for sending iMessages -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- Full Disk Access for ~/Library/Messages/chat.db -->
    <!-- Note: This must be granted manually by the user in System Settings.
         There is no entitlement to request it programmatically. -->
</dict>
</plist>
